# Copy to .env to override defaults. All values are optional.

# --- Embedding backend: auto | sentence_transformers | tfidf | openai ------
# auto = use OpenAI if OPENAI_API_KEY set, else sentence-transformers if
#        installed/downloadable, else the offline TF-IDF fallback.
embedding_backend=auto
st_model_name=sentence-transformers/all-MiniLM-L6-v2
openai_embedding_model=text-embedding-3-small

# --- Retrieval -------------------------------------------------------------
top_k=4
chunk_size=700
chunk_overlap=120

# --- Evidence sufficiency gate (cosine similarity in [0,1]) ----------------
# Thresholds are backend-specific; the gate picks the right one at runtime.
sufficiency_threshold_tfidf=0.12
sufficiency_threshold_semantic=0.35
min_supporting_chunks=1
support_floor_ratio=0.6

# --- Answer generation: extractive | openai | anthropic --------------------
# extractive (default) builds the answer only from retrieved sentences.
llm_backend=extractive
openai_chat_model=gpt-4o-mini
anthropic_model=claude-3-5-haiku-latest

# --- API keys (only needed for the hosted backends above) ------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
